# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# ---- General ----
GENERIC_TIMEZONE=America/Sao_Paulo

# ---- n8n ----
# Generate with: openssl rand -base64 32
# WARNING: once workflows are created, do NOT change this key or you will
# lose the ability to decrypt stored credentials.
N8N_ENCRYPTION_KEY=

# ---- Postgres ----
POSTGRES_USER=n8n
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# ---- Redis ----
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=

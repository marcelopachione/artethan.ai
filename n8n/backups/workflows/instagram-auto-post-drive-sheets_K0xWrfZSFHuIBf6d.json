    {
      "parameters": {
        "jsCode": "const file = $input.first().json;\nconst sheetRow = $('Sheets - Get Nao Aplicados').first().json;\nconst nome = (file.name || '').toLowerCase();\nconst isVideo = nome.endsWith('.mp4') || nome.endsWith('.mov');\nconst directUrl = `https://drive.google.com/uc?export=download&id=${file.id}`;\nreturn [{\n  json: {\n    file_id: file.id,\n    file_name: file.name,\n    media_url: directUrl,\n    media_type: isVideo ? 'REELS' : 'IMAGE',\n    caption: sheetRow.legenda || '',\n    row_number: sheetRow.row_number\n  }\n}];"
      },

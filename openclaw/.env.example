# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# ---- General ----
GENERIC_TIMEZONE=America/Sao_Paulo

# ---- OpenClaw gateway ----
# Which image to run. Pin to a version tag (e.g. ghcr.io/openclaw/openclaw:2026.2.26)
# once you've validated an upgrade, instead of tracking ":latest" in production.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Auth token clients (n8n, the CLI, etc.) must send to talk to the gateway API.
# Generate with: openssl rand -base64 32
OPENCLAW_GATEWAY_TOKEN=

OPENCLAW_LOG_LEVEL=info

# ---- Model provider (OpenRouter) ----
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use, in "openrouter/<provider>/<model>" format.
# "openrouter/auto" lets OpenRouter pick/route automatically; pin a specific
# model (e.g. openrouter/anthropic/claude-sonnet-4.5) for predictable cost/behavior.
OPENCLAW_PRIMARY_MODEL=openrouter/auto
